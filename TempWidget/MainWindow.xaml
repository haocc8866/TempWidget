<Window x:Class="TempWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TempWidget.ViewModels"
        xmlns:conv="clr-namespace:TempWidget.Converters"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="温度小窗"
        Height="110" Width="50"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <conv:TempToColorConverter x:Key="TempColor"/>
        <conv:TempToTextConverter x:Key="TempText"/>
        <BooleanToVisibilityConverter x:Key="B2V"/>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="8"
                Background="#E60E0E14"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                Padding="0,6">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="10" ShadowDepth="0"/>
            </Border.Effect>

            <Grid>
                <!-- 竖版布局 (默认) -->
                <StackPanel x:Name="VerticalLayout"
                            HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHorizontal}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <!-- CPU 块 -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,2">
                        <TextBlock Text="CPU"
                                   Foreground="#AAFFFFFF"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,1,0,0">
                            <TextBlock Text="{Binding CpuTemp, Converter={StaticResource TempText}}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{Binding CpuTemp, Converter={StaticResource TempColor}}"/>
                            <TextBlock Text="°"
                                       FontSize="9"
                                       Foreground="#88FFFFFF"
                                       VerticalAlignment="Top"
                                       Margin="1,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Height="1" Fill="#22FFFFFF" Margin="3,4"/>

                    <!-- GPU 块 -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,2">
                        <TextBlock Text="GPU"
                                   Foreground="#AAFFFFFF"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,1,0,0">
                            <TextBlock Text="{Binding GpuTemp, Converter={StaticResource TempText}}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{Binding GpuTemp, Converter={StaticResource TempColor}}"/>
                            <TextBlock Text="°"
                                       FontSize="9"
                                       Foreground="#88FFFFFF"
                                       VerticalAlignment="Top"
                                       Margin="1,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- 横版布局 -->
                <Grid x:Name="HorizontalLayout"
                      Visibility="{Binding IsHorizontal, Converter={StaticResource B2V}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CPU 列: 标签 + 数字 + 进度条 -->
                    <Grid Grid.Column="0" Margin="6,3,3,3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="CPU"
                                       Foreground="#AAFFFFFF"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CpuTemp, Converter={StaticResource TempText}}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{Binding CpuTemp, Converter={StaticResource TempColor}}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="°"
                                           FontSize="10"
                                           Foreground="#88FFFFFF"
                                           VerticalAlignment="Top"
                                           Margin="1,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <ProgressBar Grid.Row="1"
                                     Value="{Binding CpuTempPercent, Mode=OneWay}"
                                     Maximum="100"
                                     Height="3"
                                     Foreground="{Binding CpuTemp, Converter={StaticResource TempColor}}"
                                     Background="#22FFFFFF"
                                     BorderThickness="0"/>
                    </Grid>

                    <!-- 分隔线 -->
                    <Rectangle Grid.Column="0" Width="1" Fill="#22FFFFFF" HorizontalAlignment="Right" Margin="0,3"/>

                    <!-- GPU 列 -->
                    <Grid Grid.Column="1" Margin="6,3,3,3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="GPU"
                                       Foreground="#AAFFFFFF"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding GpuTemp, Converter={StaticResource TempText}}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{Binding GpuTemp, Converter={StaticResource TempColor}}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="°"
                                           FontSize="10"
                                           Foreground="#88FFFFFF"
                                           VerticalAlignment="Top"
                                           Margin="1,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <ProgressBar Grid.Row="1"
                                     Value="{Binding GpuTempPercent, Mode=OneWay}"
                                     Maximum="100"
                                     Height="3"
                                     Foreground="{Binding GpuTemp, Converter={StaticResource TempColor}}"
                                     Background="#22FFFFFF"
                                     BorderThickness="0"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- 托盘图标 -->
        <tb:TaskbarIcon
            x:Name="Tray"
            ToolTipText="温度小窗"
            TrayMouseDoubleClick="Tray_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示" Click="Show_Click"/>
                    <Separator/>
                    <MenuItem x:Name="OrientationMenu"
                              Header="切换为横版样式"
                              Click="OrientationMenu_Click"/>
                    <MenuItem x:Name="AutoStartMenu"
                              Header="开机启动"
                              IsCheckable="True"
                              Click="AutoStart_Click"/>
                    <MenuItem Header="温度刷新时间">
                        <MenuItem x:Name="Refresh1s" Header="1秒" IsCheckable="True" Tag="1" Click="RefreshInterval_Click"/>
                        <MenuItem x:Name="Refresh3s" Header="3秒" IsCheckable="True" Tag="3" Click="RefreshInterval_Click"/>
                        <MenuItem x:Name="Refresh6s" Header="6秒" IsCheckable="True" Tag="6" Click="RefreshInterval_Click"/>
                    </MenuItem>
                    <MenuItem Header="诊断: 导出 sensor 列表" Click="DumpSensors_Click"/>
                    <Separator/>
                    <MenuItem Header="退出" Click="Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
